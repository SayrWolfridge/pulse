<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>          <string>ai.hypostas.runtime</string>
    <key>ProgramArguments</key>
    <array><string>/bin/bash</string><string>/Users/iris/.pulse/run-runtime.sh</string></array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>PYTHONPATH</key> <string>/Users/iris/.openclaw/workspace</string>
        <key>HOME</key>       <string>/Users/iris</string>
        <key>SHELL</key>      <string>/bin/bash</string>
    </dict>
    <key>RunAtLoad</key>    <true/>
    <key>KeepAlive</key>    <true/>
    <key>ThrottleInterval</key>  <integer>30</integer>
    <key>StandardOutPath</key>
    <string>/Users/iris/.pulse/logs/runtime-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/iris/.pulse/logs/runtime-stderr.log</string>
</dict>
</plist>
